# Twenty5 / iPE Quote automation credentials — TEMPLATE.
#
# Setup: copy this file to `.env.local` at the repo root, then fill in real values.
#   cp .env.local.example .env.local
#
# `.env.local` is git-ignored, so your real credentials are never committed.
# These are only used when IPE_USERNAME / IPE_PASSWORD are not already set in the
# environment. Override the file path with IPE_ENV_FILE if needed.

IPE_USERNAME=your_username_here
IPE_PASSWORD=your_password_here
